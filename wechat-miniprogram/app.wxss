page {
  min-height: 100%;
  color: #2a1c12;
  background:
    radial-gradient(circle at 18% 8%, rgba(255, 255, 255, 0.7), transparent 28%),
    linear-gradient(135deg, #f6ead6, #d8b985 46%, #8c5631);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
}

.glass-card {
  border: 1rpx solid rgba(255, 255, 255, 0.52);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.58);
  box-shadow: 0 24rpx 60rpx rgba(70, 40, 18, 0.18);
  backdrop-filter: blur(18px);
}

.title {
  margin: 0 0 16rpx;
  font-size: 42rpx;
  font-weight: 700;
}

.text {
  color: rgba(42, 28, 18, 0.78);
  font-size: 28rpx;
  line-height: 1.75;
}

.button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, #8b1e17, #c46b34);
  box-shadow: 0 16rpx 34rpx rgba(139, 30, 23, 0.22);
  font-size: 28rpx;
  font-weight: 600;
}

.button.secondary {
  color: #4b2b18;
  background: rgba(255, 255, 255, 0.62);
  box-shadow: inset 0 0 0 1rpx rgba(120, 68, 26, 0.16);
}
