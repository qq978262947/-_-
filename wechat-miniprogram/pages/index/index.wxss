.web-page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

.fallback {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fallback-card {
  width: 100%;
  box-sizing: border-box;
  padding: 42rpx;
}

.fallback-card .button {
  margin-top: 28rpx;
}
